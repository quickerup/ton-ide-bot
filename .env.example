# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional webhook URL if deploying behind HTTPS
TELEGRAM_WEBHOOK_URL=

# Redis connection for session persistence
REDIS_URL=redis://localhost:6379

# Optional GitHub token for higher API rate limits and access to private repos
GITHUB_TOKEN=

# TON RPC endpoint for network access
TON_RPC_ENDPOINT=https://toncenter.com/api/v2/jsonRPC

# TON Connect URL host for deep links and manifest generation
TON_CONNECT_HOST=https://your-host.example.com

# Node environment
NODE_ENV=development
