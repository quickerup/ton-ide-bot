{
  "name": "ton-ide-bot",
  "version": "0.1.0",
  "description": "A Telegram bot for TON contract compilation, deployment, and wallet interaction using a service-oriented architecture.",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc --build",
    "start": "node dist/app.js",
    "lint": "echo 'No lint configured yet'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ton-community/func-js": "^0.11.0",
    "axios": "^1.7.7",
    "dotenv": "^16.3.1",
    "ioredis": "^5.3.2",
    "ioredis-mock": "^8.13.1",
    "telegraf": "^4.14.2",
    "ton": "^13.9.0",
    "winston": "^3.10.0",
    "zod": "^3.23.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
